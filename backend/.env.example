PORT=5001
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentic_seo?schema=public"
GEMINI_API_KEY="your-gemini-api-key-here"

# Security & Authentication Configuration
# In production, ADMIN_API_KEY must be set to protect mutation/admin endpoints.
ADMIN_API_KEY="your-secret-admin-api-key"
# Comma-separated allowed frontend origin URLs for CORS restriction
CORS_ORIGIN="http://localhost:3000,http://localhost:5001"

# Optional CMS Publishing Integrations
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USER=admin
WORDPRESS_APP_PASSWORD=your-app-password
WEBFLOW_API_TOKEN=your-webflow-token
